FLASK_ENV=development
FLASK_DEBUG=1
FLASK_APP=wsgi:app
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5000
MAX_UPLOAD_MB=16
SCAN_RATE_LIMIT=10 per minute
RATE_LIMIT_STORAGE_URI=memory://
SECRET_KEY=change-this-secret-before-production
SESSION_COOKIE_SECURE=0
USER_DB_PATH=instance/vlogshield_users.sqlite3

# Use either DATABASE_URL or the MYSQL_* settings for persistent scan history.
# DATABASE_URL=mysql://vlogshield_user:change_me@localhost:3306/vlogshield
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=vlogshield
MYSQL_USER=vlogshield_user
MYSQL_PASSWORD=change_me
